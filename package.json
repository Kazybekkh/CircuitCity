{
  "name": "circuits-as-a-city",
  "version": "1.0.0",
  "description": "Educational platform that translates electronic circuits into an animated city simulation",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
